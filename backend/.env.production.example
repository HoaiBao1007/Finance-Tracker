NODE_ENV="production"
PORT="4000"
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-region-pooler.aws.neon.tech/finance_tracker?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx-region.aws.neon.tech/finance_tracker?sslmode=require&channel_binding=require"
JWT_SECRET="replace-with-a-random-secret-at-least-32-characters"
JWT_EXPIRES_IN="7d"
CLIENT_ORIGIN="https://your-project.vercel.app"
EMAIL_PROVIDER="resend"
MAIL_FROM_EMAIL="no-reply@example.com"
MAIL_FROM_NAME="Finance Tracker"
RESEND_API_KEY="re_placeholder_api_key"
RESEND_API_BASE_URL="https://api.resend.com"
ALLOW_LOCAL_SMTP="false"
# Optional SMTP fallback when EMAIL_PROVIDER="smtp"
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-account@gmail.com"
# SMTP_PASS="your-app-password"
PASSWORD_RESET_OTP_EXPIRES_MINUTES="15"